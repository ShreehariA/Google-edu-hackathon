        <mxCell id="bckXiTj4P20fi5hhEFYR-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Not in architecture&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;ol style=&quot;padding-inline-start: 28px; color: rgb(204, 204, 204); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; font-size: 13px; text-align: start; background-color: rgb(24, 24, 24);&quot;&gt;&lt;li&gt;&lt;strong&gt;SSE (Server-Sent Events)&lt;/strong&gt;&amp;nbsp;— the streaming protocol from agent → frontend isn&#39;t called out as a distinct protocol&lt;/li&gt;&lt;li&gt;&lt;strong&gt;InMemorySessionService&lt;/strong&gt;&amp;nbsp;— agent sessions are ephemeral/in-memory, not persisted anywhere&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Embedding model&lt;/strong&gt;&amp;nbsp;—&amp;nbsp;&lt;a href=&quot;vscode-file://vscode-app/Applications/Visual%20Studio%20Code.app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html&quot; title=&quot;&quot; draggable=&quot;true&quot; data-href=&quot;file:///Users/shreeharianbazhagan/Documents/UOB/Google-edu-hackathon/RAG_Pipeline/teacher_agent/server.py#154%2C37&quot; data-keybinding-context=&quot;16494&quot; class=&quot;chat-inline-anchor-widget show-file-icons&quot; style=&quot;border-color: rgba(255, 255, 255, 0.1); border-style: solid; border-width: 1px; border-image: none 100% / 1 / 0 stretch; border-radius: 4px; margin: 0px 1px; padding: 1px 3px; text-wrap: nowrap; width: fit-content; text-decoration-line: none; user-select: text;&quot;&gt;&lt;span class=&quot;icon-label&quot; style=&quot;padding: 0px 3px; text-wrap: wrap;&quot;&gt;text-multilingual-embedding-002&lt;/span&gt;&lt;/a&gt;&amp;nbsp;used by ScopeGateAgent for chapter matching (separate from RAG)&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Cloud Run auto-scaling / load balancer&lt;/strong&gt;&amp;nbsp;— implicit but not shown&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Environment variables&lt;/strong&gt;&amp;nbsp;—&amp;nbsp;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; font-size: 11.999px; color: rgb(208, 208, 208); background-color: rgb(60, 60, 60); padding: 1px 3px; border-radius: 4px; border-color: rgb(208, 208, 208); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve;&quot;&gt;GOOGLE_GENAI_USE_VERTEXAI&lt;/code&gt;,&amp;nbsp;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; font-size: 11.999px; color: rgb(208, 208, 208); background-color: rgb(60, 60, 60); padding: 1px 3px; border-radius: 4px; border-color: rgb(208, 208, 208); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve;&quot;&gt;GOOGLE_CLOUD_PROJECT&lt;/code&gt;,&amp;nbsp;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; font-size: 11.999px; color: rgb(208, 208, 208); background-color: rgb(60, 60, 60); padding: 1px 3px; border-radius: 4px; border-color: rgb(208, 208, 208); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve;&quot;&gt;BACKEND_URL&lt;/code&gt;,&amp;nbsp;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; font-size: 11.999px; color: rgb(208, 208, 208); background-color: rgb(60, 60, 60); padding: 1px 3px; border-radius: 4px; border-color: rgb(208, 208, 208); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve;&quot;&gt;AGENT_URL&lt;/code&gt;&amp;nbsp;flowing into services&lt;/li&gt;&lt;li&gt;&lt;strong&gt;GitHub&lt;/strong&gt;&amp;nbsp;— source control / the repo itself&lt;/li&gt;&lt;li&gt;&lt;strong&gt;&lt;a href=&quot;vscode-file://vscode-app/Applications/Visual%20Studio%20Code.app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html&quot; title=&quot;&quot; draggable=&quot;true&quot; data-href=&quot;file:///Users/shreeharianbazhagan/Documents/UOB/Google-edu-hackathon/RAG_Pipeline/teacher_agent/sub_agents/performance_agent/agent.py#146%2C5&quot; data-keybinding-context=&quot;16495&quot; class=&quot;chat-inline-anchor-widget show-file-icons&quot; style=&quot;border-color: rgba(255, 255, 255, 0.1); border-style: solid; border-width: 1px; border-image: none 100% / 1 / 0 stretch; border-radius: 4px; margin: 0px 1px; padding: 1px 3px; text-wrap: nowrap; width: fit-content; font-weight: 400; text-decoration-line: none; user-select: text;&quot;&gt;&lt;span class=&quot;icon-label&quot; style=&quot;padding: 0px 3px; text-wrap: wrap;&quot;&gt;before_tool_callback&lt;/span&gt;&lt;/a&gt;&amp;nbsp;(tenant isolation)&lt;/strong&gt;&amp;nbsp;— the security guardrail on BigQueryToolset isn&#39;t represented&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Cloud Run service URLs&lt;/strong&gt;&amp;nbsp;— the actual URLs on each service box&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Browser localStorage/sessionStorage&lt;/strong&gt;&amp;nbsp;— where dashboard data is cached client-side&lt;/li&gt;&lt;li&gt;&lt;b&gt;Seed data -&amp;nbsp;&lt;/b&gt;using local python code to load into bigquery&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
